# Supabase
SUPABASE_ANON_KEY=
SUPABASE_REDIRECT_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=

# Redis — Upstash (use rediss:// for TLS, e.g. rediss://default:TOKEN@HOST:PORT)
# Local dev: redis://localhost:6379
REDIS_URL=

# Queue
QUEUE_PREFIX=dev
WORKER_CONCURRENCY=5

# OAuth — YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=

# OAuth — X
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=

# AI
OPENAI_API_KEY=
PERSPECTIVE_API_KEY=

# Billing
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_PLUS_ID=
POLAR_PRODUCT_PRO_ID=
POLAR_PRODUCT_STARTER_ID=
POLAR_WEBHOOK_SECRET=

# Email
RESEND_API_KEY=

# App
NODE_ENV=development
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Frontend (Vite — prefix with VITE_)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:3000
