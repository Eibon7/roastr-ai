{
  "name": "roastr-ai",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "supabase:start": "bash scripts/supabase-local.sh start",
    "supabase:stop": "bash scripts/supabase-local.sh stop",
    "supabase:reset": "bash scripts/supabase-local.sh reset"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20"
  }
}
